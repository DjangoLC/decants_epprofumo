# ─── Supabase (atribución gclid) ─────────────────────────────
# Proyecto Supabase para guardar la atribución de Google Ads (gclid).
NEXT_PUBLIC_SUPABASE_URL=
# Service role key: SOLO se usa en el servidor (API routes). Nunca exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Microsoft Clarity (heatmaps + session recordings) ───────
NEXT_PUBLIC_CLARITY_ID=

# ─── Instagram Graph API (scaffolding: feed + refresh de token) ─
IG_ACCESS_TOKEN=
IG_USER_ID=
# Secreto opcional para proteger el endpoint de cron de Vercel.
CRON_SECRET=
